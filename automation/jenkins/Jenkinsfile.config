// =======================================================================
// PIPELINE: Jenkinsfile.config
//
// PURPOSE: Re-run ONLY Ansible configuration steps without Terraform.
//          Use this when infra already exists (Terraform already ran)
//          but you need to re-configure servers or re-deploy EKS components.
//
//   Stage 1: Configure Jenkins Server  (jenkins.yml)
//   Stage 2: Configure Jump Server     (jump_server.yml)
//   Stage 3: Deploy EKS Components     (eks.yml)
//
// NOTE: mgmt_server.yml is intentionally excluded — the infra-mgmt-server
//       bootstraps itself via EC2 userdata at launch time.
//
// AGENT: infra-mgmt (Jenkins agent on infra-mgmt-server)
//        This agent has: Ansible, private_key.pem, inventory.ini
// =======================================================================
pipeline {
    agent { label 'infra-mgmt' }

    environment {
        ANSIBLE_HOST_KEY_CHECKING = 'False'
        SONAR_TOKEN               = credentials('sonar-token')
        GITHUB_TOKEN              = credentials('github')
        AWS_ACCOUNT_ID            = credentials('AWS_ACCOUNT_ID')
    }

    stages {
        stage('Checkout') {
            steps {
                git branch: 'main',
                    credentialsId: 'GITHUB',
                    url: 'https://github.com/ANIKHILT600/devops-mern-stack.git'
            }
        }

        stage('Verify Ansible & Inventory') {
            steps {
                sh '''
                    echo "=== Ansible Version ==="
                    ansible --version
                    echo "=== Inventory ==="
                    cat automation/ansible/inventory.ini
                    echo "=== Private Key ==="
                    ls -la automation/ansible/private_key.pem
                    echo "=== Connectivity Test ==="
                    cd automation/ansible && ansible all -i inventory.ini -m ping
                '''
            }
        }

        stage('Configure Jenkins Server') {
            // Installs Jenkins, plugins, admin user, agent node, all credentials
            steps {
                dir('automation/ansible') {
                    sh """
                        ansible-playbook -i inventory.ini jenkins.yml \\
                        --extra-vars "sonar_token=${SONAR_TOKEN} \\
                                      github_token=${GITHUB_TOKEN} \\
                                      github_username=ANIKHILT600 \\
                                      aws_account_id=${AWS_ACCOUNT_ID} \\
                                      aws_access_key=NOT_NEEDED_IAM_ROLE \\
                                      aws_secret_key=NOT_NEEDED_IAM_ROLE" \\
                        -v
                    """
                }
            }
        }

        stage('Configure Jump Server') {
            // Installs kubectl, eksctl, helm, AWS CLI on jump server
            steps {
                dir('automation/ansible') {
                    sh 'ansible-playbook -i inventory.ini jump_server.yml -v'
                }
            }
        }

        stage('Deploy EKS Components') {
            // Deploys: LB Controller, ArgoCD, Prometheus+Grafana, ECR secret, ArgoCD apps
            steps {
                dir('automation/ansible') {
                    sh 'ansible-playbook -i inventory.ini eks.yml -v'
                }
            }
        }
    }

    post {
        success {
            echo '''
            ╔══════════════════════════════════════════════════════╗
            ║  ✅ All servers and EKS configured successfully!     ║
            ║  Next: Run App-Deploy-Backend and App-Deploy-Frontend ║
            ╚══════════════════════════════════════════════════════╝
            '''
        }
        failure {
            echo '❌ Configuration failed — check the Ansible output above for the failing task'
        }
    }
}

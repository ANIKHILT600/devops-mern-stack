# =============================================================================
# .gitignore — DevSecOps MERN Stack Project
# =============================================================================

# =============================================================================
# TERRAFORM
# =============================================================================

# Provider plugins downloaded by terraform init (~hundreds of MB)
**/.terraform/

# Local Terraform state — NEVER commit, state lives in S3 (see backend.tf)
*.tfstate
*.tfstate.backup

# Binary plan file produced by terraform plan -out=tfplan
# Not human-readable and environment-specific; re-run plan before apply
tfplan
tfplan.out
*.tfplan

# Terraform crash log
crash.log
crash.*.log

# Override files — local developer overrides, not shared
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Terraform-generated outputs file (created by Jenkinsfile.infra pipeline stage)
automation/terraform/outputs.json

# =============================================================================
# TERRAFORM LOCK FILE — DO NOT IGNORE
# .terraform.lock.hcl MUST be committed to ensure every developer and
# CI agent uses the same provider versions. Remove it from this block if
# you accidentally added it to a previous gitignore.
# =============================================================================
# .terraform.lock.hcl   ← intentionally NOT ignored

# =============================================================================
# ANSIBLE — GENERATED / SENSITIVE FILES
# =============================================================================

# inventory.ini is AUTO-GENERATED by terraform apply via inventory.tpl.
# It contains real server IP addresses.
# To push it after terraform apply, use: git add --force automation/ansible/inventory.ini
automation/ansible/inventory.ini

# private_key.pem is AUTO-GENERATED by terraform apply (TLS resource).
# SECURITY: Private SSH keys must never be permanently stored in Git.
# Exception: this project needs it in Git for infra-mgmt server to clone.
# To push after terraform apply, use: git add --force automation/ansible/private_key.pem
# Re-evaluate using AWS Secrets Manager / SSM Parameter Store for production.
*.pem

# Ansible retry files created when playbooks fail
*.retry

# =============================================================================
# TRIVY SECURITY SCAN REPORTS
# These are created inside the Jenkins workspace by Jenkinsfile-Backend/Frontend.
# They should not be committed — review them in Jenkins console output.
# =============================================================================
trivyfs.txt
trivyimage.txt
trivy-results*.txt
trivy-results*.json

# =============================================================================
# NODE.JS / APPLICATION CODE
# =============================================================================

# Dependencies — never commit, installed via npm install on the target
node_modules/
.npm/
.node_repl_history

# Build artifacts
dist/
build/

# npm/yarn logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnp
.pnp.js

# =============================================================================
# ENVIRONMENT VARIABLES / SECRETS
# =============================================================================

# Local environment variable files — NEVER commit secrets
.env
.env.local
.env.*.local
.env.development
.env.production
.env.test

# AWS credential files
.aws/credentials
.aws/config

# =============================================================================
# OPERATING SYSTEM FILES
# =============================================================================

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# Linux
*~

# =============================================================================
# IDE / EDITOR FILES
# =============================================================================

# VS Code — ignore workspace-level settings but allow shared config
.vscode/
!.vscode/extensions.json     # share recommended extensions if present

# JetBrains IDEs (IntelliJ, PyCharm, GoLand)
.idea/
*.iml
*.iws
*.ipr

# Vim
*.swp
*.swo
.netrwhist

# Emacs
*~
\#*\#

# =============================================================================
# DOCKER
# =============================================================================

# Docker context archives (produced by docker build in some setups)
*.tar

# =============================================================================
# LOGS (general)
# =============================================================================

# Application and system logs generated at runtime
*.log

# NOTE: *.md (Markdown) is intentionally NOT ignored.
# README.md, Automation_Implementation.md, Manual_Implementation.md
# are essential project documentation and must be version-controlled.
